@startuml
!include ../src/Utils.puml
''----------------------------------------------------------------------------------------------------------------------
'' Tests
''----------------------------------------------------------------------------------------------------------------------
!procedure get_library_version_returns_semantic_version_number()
    '' Arrange, Act
    !$actual = $get_library_version()

    '' Assert
    !$pattern = "/^(0|[1-9]\d*)\.(0|[1-9]\d*)\.(0|[1-9]\d*)(?:-((?:0|[1-9]\d*|\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\.(?:0|[1-9]\d*|\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\+([0-9a-zA-Z-]+(?:\.[0-9a-zA-Z-]+)*))?$/gm"
    !assert %size(%splitstr_regex($actual, $pattern)) == 1
!endprocedure
''----------------------------------------------------------------------------------------------------------------------
!procedure format_should_create_a_string_from_pattern_and_positional_arguments()
    '' Arrange, Act
    !$actual = $format("This is %1 with arguments %2 and %3.", "expression", "x", "y")

    '' Assert
    !assert "This is expression with arguments x and y." == $actual
!endprocedure
''----------------------------------------------------------------------------------------------------------------------
!procedure contain_in_list_should_find_existing_item()
    '' Arrange
    !$collection = [1, 2, 3]

    '' Act
    !$exists = $contain_in_list($collection, 2)

    '' Assert
    !assert $exists == %true()
!endprocedure
''----------------------------------------------------------------------------------------------------------------------
!procedure contain_in_list_should_not_find_missing_item()
    '' Arrange
    !$collection = [1, 2, 3]

    '' Act
    !$exists = $contain_in_list($collection, 4)

    '' Assert
    !assert $exists == %false()
!endprocedure
''----------------------------------------------------------------------------------------------------------------------
'' Tests RUN!
''----------------------------------------------------------------------------------------------------------------------
get_library_version_returns_semantic_version_number()
format_should_create_a_string_from_pattern_and_positional_arguments()
contain_in_list_should_find_existing_item()
contain_in_list_should_not_find_missing_item()
''----------------------------------------------------------------------------------------------------------------------
caption OK
@enduml