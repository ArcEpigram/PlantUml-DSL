@startuml
''----------------------------------------------------------------------------------------------------------------------
'' Get PlantUml DSL library version.
'' example: !$ver = $get_library_version()
!function $get_library_version()
    !if %file_exists("../version.json")
        !$ver = %load_json("../version.json")
    !else if %file_exists("version.json")
        !$ver = %load_json("version.json")
    !endif
    !return $ver.version
!endfunction
''----------------------------------------------------------------------------------------------------------------------
'' Prints trace messages in tabular form directly onto the diagram.
!procedure $trace($message, $source="")
    !$TRACE_MESSAGES = "log_messages"
    !if $source == ""
        !$source = %filename()
    !endif

    !if (%not(%variable_exists($TRACE_MESSAGES)))
        $__init_trace_log($TRACE_MESSAGES)
    !endif

    !$log_messages = %get_variable_value($TRACE_MESSAGES)

    !if %mod(%size($log_messages), 2) == 0
        !$row_color = "<#f0f0f0>"
    !else
        !$row_color = "<#white>"
    !endif

    !$current_row_number = %size($log_messages)

    !$log_row = $format('%1| %2 | %3 | %4 |', $row_color, $current_row_number, $message, $source)
    !$log_messages = $append_to_list($log_messages, $log_row)
    %set_variable_value($TRACE_MESSAGES, $log_messages)

    title
    Трассировочные сообщения:
    !foreach $row in $log_messages
    $row
    !endfor
    end title
!endprocedure
''----------------------------------------------------------------------------------------------------------------------
!procedure $trace_clear()
    $__init_trace_log("log_messages")
!endprocedure
''----------------------------------------------------------------------------------------------------------------------
!procedure $__init_trace_log($msg_list)
    !$log_messages = [\
        "<#lightyellow>|= # |= Message |= Source |"\
    ]
    %set_variable_value($msg_list, $log_messages)
!endprocedure
''----------------------------------------------------------------------------------------------------------------------
'' Converts the value of objects to strings based on the
'' formats specified and inserts them into another string.
'' example: !$text = $format("This is %1 with arguments %2 and %3.", "expression", "x", "y")
!function $format($text, $p1, $p2="", $p3="", $p4="", $p5="", $p6="", $p7="", $p8="")
    !$result = ""
    !$pos1 = %strpos($text, "%1")
    !$pos2 = %strpos($text, "%2")
    !$pos3 = %strpos($text, "%3")
    !$pos4 = %strpos($text, "%4")
    !$pos5 = %strpos($text, "%5")
    !$pos6 = %strpos($text, "%6")
    !$pos7 = %strpos($text, "%7")
    !$pos8 = %strpos($text, "%8")

    !foreach $fragment in %splitstr($text, "%")
        !if (%substr($fragment, 0, 1) == "1")
            !$result = $result + $p1 + %substr($fragment, 1, %strlen($fragment) - 1)
        !elseif (%substr($fragment, 0, 1) == "2")
            !$result = $result + $p2 + %substr($fragment, 1, %strlen($fragment) - 1)
        !elseif (%substr($fragment, 0, 1) == "3")
            !$result = $result + $p3 + %substr($fragment, 1, %strlen($fragment) - 1)
        !elseif (%substr($fragment, 0, 1) == "4")
            !$result = $result + $p4 + %substr($fragment, 1, %strlen($fragment) - 1)
        !elseif (%substr($fragment, 0, 1) == "5")
            !$result = $result + $p5 + %substr($fragment, 1, %strlen($fragment) - 1)
        !elseif (%substr($fragment, 0, 1) == "6")
            !$result = $result + $p6 + %substr($fragment, 1, %strlen($fragment) - 1)
        !elseif (%substr($fragment, 0, 1) == "7")
            !$result = $result + $p7 + %substr($fragment, 1, %strlen($fragment) - 1)
        !elseif (%substr($fragment, 0, 1) == "8")
            !$result = $result + $p8 + %substr($fragment, 1, %strlen($fragment) - 1)
        !else
            !$result = $result + $fragment
        !endif
    !endfor

    !return $result
!endfunction
''----------------------------------------------------------------------------------------------------------------------
'' Checks whether an item exists in a collection.
'' args: $collection - JSON array to search in
''       $item - item to look for
'' returns: %true() if $item is found in $collection, %false() otherwise
'' example: !$found = $contain_in_list($my_array, "target_value")
!function $contain_in_list($collection, $item)
    !$exists = %false()
    !foreach $e in $collection
        !if $e == $item
            !return %true()
        !endif
    !endfor
    !return $exists
!endfunction
''----------------------------------------------------------------------------------------------------------------------
'' Appends an item to a JSON array and returns the modified array.
'' args: $collection - JSON array to append to
''       $item - JSON-object, string or number
'' returns: new JSON array with $item appended at the end
'' example: !$extended = $append_to_list($my_array, "new_value")
!function $append_to_list($collection, $item)
    !$str = %string($collection)
    !$len = %strlen($str)
    !$item_raw = %string($item)
    !$first_char = %substr($item_raw, 0, 1)
    !if $item_raw == "true" || $item_raw == "false" || $item_raw == "null"
        !$json_item = $item_raw
    !elseif $first_char == "{" || $first_char == "[" || $first_char == '"'
        !$json_item = $item_raw
    !elseif %strpos("0123456789", $first_char) >= 0 || $first_char == "-" || $first_char == "."
        !$json_item = $item_raw
    !else
        !$json_item = $format('"%1"', $item_raw)
    !endif
    !if $len == 2
        !return %str2json($format("[%1]", $json_item))
    !endif
    !$without_bracket = %substr($str, 0, $len - 1)
    !$with_item = $format("%1, %2]", $without_bracket, $json_item)
    !return %str2json($with_item)
!endfunction
''----------------------------------------------------------------------------------------------------------------------
'' Adds a key-value pair to a JSON object and returns the modified object.
'' args: $json - JSON object to add to
''       $key - key name (string)
''       $value - JSON-object, string, number, boolean or null
'' returns: new JSON object with the key-value pair added
'' example: !$obj = $json_add($obj, "name", "Alice")
!function $json_add($json, $key, $value)
    !$str = %string($json)
    !$len = %size($str)

    !$value_raw = %string($value)
    !$first_char = %substr($value_raw, 0, 1)
    !if $value_raw == "true" || $value_raw == "false" || $value_raw == "null"
        !$json_value = $value_raw
    !elseif $first_char == "{" || $first_char == "[" || $first_char == '"'
        !$json_value = $value_raw
    !elseif %strpos("0123456789", $first_char) >= 0 || $first_char == "-" || $first_char == "."
        !$json_value = $value_raw
    !else
        !$json_value = $format('"%1"', $value_raw)
    !endif

    !$json_key = $format('"%1"', $key)

    !if $len == 2
        !return %str2json($format("{%1: %2}", $json_key, $json_value))
    !endif

    !$without_brace = %substr($str, 0, $len - 1)
    !return %str2json($format("%1, %2: %3}", $without_brace, $json_key, $json_value))

!endfunction
''----------------------------------------------------------------------------------------------------------------------
'' Force the script execution abort with error.
'' args: $message - error message to display
''       $source - source file name (defaults to %filename())
'' example: $fail("Something went wrong")
!procedure $fail($message, $source=%filename())
    !assert %false() : $format('FAIL: "%1" in "%2"', $message, $source)
!endprocedure

@enduml
